function renderFeed(){
  if(navF==='admin')return;
  let fl=posts.filter(p=>p.approved);
  if(navF==='mine'){
    if(cu.isOwner||cu.isAdmin)fl=[...posts];
    else if(cu.role==='coach')fl=posts.filter(p=>p.coach===cu.name);
    else fl=posts.filter(p=>p.appliedBy.includes(cu.name));
  }else if(navF==='open')fl=fl.filter(p=>p.status==='open');
  else if(navF==='upcoming')fl=fl.filter(p=>p.status==='upcoming');
  if(chipF!=='all')fl=fl.filter(p=>p.status===chipF);
  if(sportF!=='all')fl=fl.filter(p=>p.sport===sportF);
  const fc=document.getElementById('feed');
  if(!fl.length){fc.innerHTML='<div class="empty"><div class="ei">🏟️</div><p>No trials found.</p></div>';return;}
  fc.innerHTML=fl.map(buildCard).join('');
}

function buildCard(p){
  const sc=SC[p.sport]||'#888',si2=SI[p.sport]||'🏆';
  const isMineCoach=cu.role==='coach'&&p.coach===cu.name&&!cu.isAdmin&&!cu.isOwner;
  const liked=p.likedBy.includes(cu.name),applied=p.appliedBy.includes(cu.name);
  const sbMap={open:`<span class="sb sbo"><span class="sdts"></span>${L().open||'Open'}</span>`,upcoming:`<span class="sb sbu"><span class="sdts"></span>${L().upcoming_s||'Upcoming'}</span>`,closed:`<span class="sb sbc"><span class="sdts"></span>${L().closed||'Closed'}</span>`};
  const pBadge=!p.approved?`<span class="sb sbp"><span class="sdts"></span>Pending</span>`:'';
  const banner=p.bannerUrl?`<img class="tcbanner" src="${p.bannerUrl}"/>`:`<div class="tcbnph" style="background:linear-gradient(135deg,${sc}12,${sc}07)">${si2}</div>`;

  const docLabels=(p.docs||[]).map(d=>{
    if(d.startsWith('custom:'))return{icon:'📎',label:d.replace('custom:','')};
    return DOCS.find(x=>x.id===d)||null;
  }).filter(Boolean);
  const docsH=docLabels.length?`<div class="docsbox"><div class="docsbox-title">${L().docs_req_label||'📄 Documents Required'}</div><div class="docsbox-list">${docLabels.map(d=>`<span class="dtag">${d.icon} ${d.label}</span>`).join('')}</div>${p.docNote?`<div style="font-size:11px;color:var(--t3);margin-top:7px;font-style:italic">📌 ${p.docNote}</div>`:''}</div>`:'';

  const skillsH=p.skills&&p.skills.length?`<div class="pill-row">${p.skills.map(s=>`<span class="ptag">⚡ ${s}</span>`).join('')}</div>`:'';
  const eligH=[p.ageGroup&&`<span class="ptag">👤 ${p.ageGroup}</span>`,p.level&&p.level!=='Any Level'&&`<span class="ptag">📊 ${p.level}</span>`,p.gender&&p.gender!=='Open to All'&&`<span class="ptag">🚻 ${p.gender}</span>`].filter(Boolean).join('');
  const contactH=p.phone&&p.approved?`<div class="cbar">📞 <b>${p.phone}</b>${p.wa?' · 💬 '+p.wa:''}${p.email?' · 📧 '+p.email:''}</div>`:'';

  // INFO GRID — only show filled fields
  const infoItems=[];
  if(p.date)infoItems.push({lbl:'Date',val:p.date});
  if(p.time)infoItems.push({lbl:'Time',val:p.time});
  if(p.location)infoItems.push({lbl:'Location',val:p.location,sm:true});
  if(p.slots)infoItems.push({lbl:'Slots',val:`${p.applicants}/${p.slots}`});
  const infoH=infoItems.length?`<div class="igrid" style="grid-template-columns:repeat(${Math.min(infoItems.length,4)},1fr)">${infoItems.map(i=>`<div class="ibox"><div class="ilbl">${i.lbl}</div><div class="ival" ${i.sm?'style="font-size:10px"':''}>${i.val}</div></div>`).join('')}</div>`:'';

  // APPLY BUTTON
  let apSec='';
  if(cu.isOwner||cu.isAdmin){
    apSec=`<button class="edit-btn" onclick="openEdit(${p.id})">✏️ Edit</button>`;
  }else if(cu.role==='player'){
    if(p.status==='closed')apSec=`<button class="apbtn cld">${L().closed_t}</button>`;
    else if(applied)apSec=`<button class="apbtn applied">${L().applied}</button>`;
    else apSec=`<button class="apbtn" onclick="applyT(${p.id})">${L().apply_now}</button>`;
  }else if(isMineCoach&&p.status==='open'){
    apSec=`<button class="apbtn ccb" onclick="closeT(${p.id})">${L().close_trial}</button>`;
  }

  const cmH=p.comments.slice(0,3).map(c=>`<div class="cmt"><div class="cmav ${c.role==='coach'||c.role==='admin'||c.role==='owner'?'cc':''}">${c.user.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase()}</div><div><div class="cmnm">${c.user}</div><div class="cmtx">${c.text}</div></div></div>`).join('');
  const cls=!p.approved?'pc':'tc';
  const pendBanner=!p.approved?`<div class="pco"></div><div class="plbl">⏳ PENDING ADMIN REVIEW</div>`:'';

  return`<div class="${cls}" id="card-${p.id}">${pendBanner}${banner}
    <div class="tcbody">
      <div class="tctop">
        <div class="tccrow"><div class="tcav">${p.coach.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase()}</div>
          <div><div class="tcnm">${p.coach}</div><div class="tccl">${p.club}</div></div>
        </div>
        <div class="tcbadges"><span class="tcts">${p.ts}</span>${sbMap[p.status]||''}${pBadge}</div>
      </div>
      <span class="stag" style="background:${sc}18;color:${sc};border:1px solid ${sc}30">${si2} ${p.sport}</span>
      <div class="tctitle">${p.title}</div>
      ${p.desc?`<div class="tcdesc">${p.desc}</div>`:''}
      ${infoH}
      ${eligH?`<div class="pill-row">${eligH}</div>`:''}
      ${skillsH}
      ${p.offer?`<div style="font-size:12px;color:var(--t2);margin-bottom:10px">🎁 <b>${L().if_sel}</b> ${p.offer}</div>`:''}
      ${p.bring?`<div style="font-size:12px;color:var(--t2);margin-bottom:10px">🎒 <b>${L().bring_lbl}</b> ${p.bring}</div>`:''}
      ${p.notes?`<div style="font-size:12px;color:var(--t3);margin-bottom:10px;font-style:italic">📌 ${p.notes}</div>`:''}
      ${docsH}
      ${contactH}
      <div class="tca">
        <button class="abt ${liked?'liked':''}" onclick="togLike(${p.id})">${liked?'❤️':'🤍'} ${p.likes}</button>
        <button class="abt" onclick="togCm(${p.id})">💬 ${p.comments.length}</button>
        <button class="abt" onclick="showN('🔗 Link copied!','info')">🔗</button>
        ${apSec}
      </div>
      <div class="cmw" id="cmw-${p.id}">
        <div id="cml-${p.id}">${cmH}</div>
        <div class="cmir"><input class="cmin" id="cmi-${p.id}" placeholder="Add a comment…" onkeydown="if(event.key==='Enter')addCm(${p.id})"/><button class="cmsnd" onclick="addCm(${p.id})">↑</button></div>
      </div>
    </div></div>`;
}

