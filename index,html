<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>TrialZone</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#06090f;--surf:#0c1018;--card:#111520;--card2:#161c28;
  --bdr:#1a2235;--bdr2:#222f45;
  --acc:#2563eb;--accl:#3b82f6;--accd:#1d4ed8;--ag:rgba(37,99,235,.13);
  --gr:#16a34a;--ye:#ca8a04;--re:#dc2626;--pu:#7c3aed;
  --t1:#f1f5f9;--t2:#94a3b8;--t3:#475569;--t4:#2d3a50;
  --mob:56px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:'Manrope',sans-serif;background:var(--bg);color:var(--t1);min-height:100vh;overflow-x:hidden;padding-bottom:var(--mob)}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:var(--bdr2);border-radius:3px}

/* ─ NAVBAR ─ */
.navbar{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(6,9,15,.97);
  backdrop-filter:blur(20px);border-bottom:1px solid var(--bdr);
  height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 16px}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:3px;
  background:linear-gradient(135deg,#2563eb,#60a5fa);-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text}
.nav-right{display:flex;align-items:center;gap:8px}

/* LANG DROPDOWN */
.lang-wrap{position:relative}
.lang-toggle{display:flex;align-items:center;gap:5px;padding:6px 12px;
  background:var(--card);border:1px solid var(--bdr);border-radius:20px;
  cursor:pointer;font-size:12px;font-weight:700;color:var(--t2);transition:all .15s;
  font-family:'Manrope',sans-serif}
.lang-toggle:hover{border-color:var(--bdr2);color:var(--t1)}
.lang-toggle .globe{font-size:15px}
.lang-drop{position:absolute;top:calc(100% + 8px);right:0;
  background:var(--card);border:1px solid var(--bdr);border-radius:12px;
  overflow:hidden;min-width:150px;z-index:200;
  opacity:0;pointer-events:none;transform:translateY(-6px);transition:all .2s}
.lang-drop.open{opacity:1;pointer-events:all;transform:translateY(0)}
.lang-opt{display:flex;align-items:center;gap:9px;padding:10px 14px;
  cursor:pointer;font-size:13px;font-weight:600;color:var(--t2);transition:all .15s}
.lang-opt:hover{background:var(--surf);color:var(--t1)}
.lang-opt.active{color:var(--accl);background:var(--ag)}
.lang-opt .lfl{font-size:16px}

.uav-wrap{display:flex;align-items:center;gap:6px}
.uav{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-weight:800;font-size:12px}
.uav.coach{background:rgba(37,99,235,.2);color:#60a5fa;border:2px solid rgba(37,99,235,.4)}
.uav.player{background:rgba(22,163,74,.2);color:#4ade80;border:2px solid rgba(22,163,74,.4)}
.uav.admin{background:rgba(124,58,237,.2);color:#a78bfa;border:2px solid rgba(124,58,237,.4)}
.rpill{padding:2px 8px;border-radius:20px;font-size:9px;font-weight:800;letter-spacing:.5px;text-transform:uppercase}
.rpill.coach{background:rgba(37,99,235,.15);color:#60a5fa}
.rpill.player{background:rgba(22,163,74,.12);color:#4ade80}
.rpill.admin{background:rgba(124,58,237,.12);color:#a78bfa}
.nibn{width:32px;height:32px;border-radius:9px;border:1px solid var(--bdr);background:var(--card);
  color:var(--t2);display:flex;align-items:center;justify-content:center;cursor:pointer;
  font-size:15px;transition:all .15s;position:relative}
.nibn:hover{border-color:var(--acc);color:var(--t1)}
.bdot{position:absolute;top:-2px;right:-2px;width:8px;height:8px;
  background:var(--re);border-radius:50%;border:2px solid var(--bg)}
.out-btn{padding:5px 11px;background:transparent;border:1px solid var(--bdr);
  border-radius:8px;color:var(--t3);font-size:11px;cursor:pointer;transition:all .2s;
  font-family:'Manrope',sans-serif}
.out-btn:hover{border-color:var(--re);color:var(--re)}

/* ─ LOGIN ─ */
#login-screen{position:fixed;inset:0;z-index:150;background:var(--bg);
  display:flex;align-items:center;justify-content:center;padding:16px;padding-top:72px;overflow-y:auto}
.login-wrap{width:100%;max-width:420px}
.login-logo{text-align:center;margin-bottom:22px}
.logo-txt{font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:5px;
  background:linear-gradient(135deg,#2563eb,#93c5fd);-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.logo-sub{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:4px;
  color:var(--t3);text-transform:uppercase;margin-top:4px}
.lcard{background:var(--card);border:1px solid var(--bdr);border-radius:20px;padding:26px 22px}
.role-tabs{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:20px;
  background:var(--surf);border-radius:12px;padding:5px;border:1px solid var(--bdr)}
.rtab{padding:11px 6px;border-radius:8px;border:none;background:transparent;
  color:var(--t3);font-family:'Manrope',sans-serif;font-size:13px;font-weight:700;
  cursor:pointer;transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:3px}
.rtab .ri{font-size:20px}
.rtab.active.coach{background:rgba(37,99,235,.15);color:#60a5fa}
.rtab.active.player{background:rgba(22,163,74,.12);color:#4ade80}
.fld{margin-bottom:14px}
.fld label{display:block;font-family:'JetBrains Mono',monospace;font-size:8px;
  letter-spacing:2px;text-transform:uppercase;color:var(--t3);margin-bottom:7px}
.fld input,.fld select{width:100%;padding:13px 14px;background:var(--surf);border:1px solid var(--bdr);
  border-radius:10px;color:var(--t1);font-family:'Manrope',sans-serif;font-size:15px;
  outline:none;transition:all .2s;-webkit-appearance:none}
.fld input:focus,.fld select:focus{border-color:var(--acc);box-shadow:0 0 0 3px var(--ag)}
.fld select option{background:var(--card)}
.lbtn{width:100%;padding:14px;border:none;border-radius:11px;font-family:'Manrope',sans-serif;
  font-size:15px;font-weight:800;cursor:pointer;transition:all .2s;margin-top:4px}
.lbtn.cb{background:var(--acc);color:#fff}
.lbtn.pb{background:var(--gr);color:#fff}
.lbtn:hover{filter:brightness(1.1);transform:translateY(-1px)}

/* ─ APP ─ */
#app{display:none;padding-top:56px}
.app-wrap{display:flex;min-height:calc(100vh - 56px)}

/* SIDEBAR */
.sidebar{width:220px;flex-shrink:0;border-right:1px solid var(--bdr);
  position:sticky;top:56px;height:calc(100vh - 56px);overflow-y:auto;padding:16px 12px}
.slbl{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:2px;
  text-transform:uppercase;color:var(--t4);margin-bottom:9px;padding-left:8px}
.si{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:10px;
  cursor:pointer;transition:all .15s;font-size:13px;font-weight:600;color:var(--t2);margin-bottom:2px}
.si:hover{background:var(--surf);color:var(--t1)}
.si.active{background:var(--ag);color:var(--accl)}
.sico{font-size:15px;width:18px;text-align:center}
.scnt{margin-left:auto;background:var(--surf);border-radius:20px;padding:1px 7px;font-size:10px;font-weight:700;color:var(--t3)}
.scnt.pnd{background:rgba(202,138,4,.15);color:var(--ye)}
.spp{display:flex;align-items:center;gap:7px;padding:7px 10px;border-radius:8px;
  cursor:pointer;transition:all .15s;font-size:12px;color:var(--t2);margin-bottom:2px}
.spp:hover,.spp.active{background:var(--surf);color:var(--t1)}
.spdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* FEED */
.feed-area{flex:1;min-width:0;padding:16px 14px}
@media(min-width:768px){.feed-area{padding:20px 24px}}

/* RIGHT PANEL */
.rpanel{width:260px;flex-shrink:0;border-left:1px solid var(--bdr);
  position:sticky;top:56px;height:calc(100vh - 56px);overflow-y:auto;padding:16px 14px}
.rpt{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:2px;
  text-transform:uppercase;color:var(--t4);margin-bottom:11px}
.rpsc{margin-bottom:22px}
.sgrid{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.sb2{background:var(--card);border:1px solid var(--bdr);border-radius:10px;padding:12px;text-align:center}
.snum{font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:1px;color:var(--accl);line-height:1}
.slb{font-size:10px;color:var(--t3);margin-top:2px}
.cr{display:flex;align-items:center;gap:9px;padding:7px;border-radius:9px;cursor:pointer;transition:all .15s;margin-bottom:3px}
.cr:hover{background:var(--surf)}
.crav{width:32px;height:32px;border-radius:50%;background:rgba(37,99,235,.12);border:1px solid rgba(37,99,235,.25);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#60a5fa;flex-shrink:0}
.cri{flex:1;min-width:0}
.crn{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.crc{font-size:10px;color:var(--t2);margin-top:1px}
.fwb{padding:3px 9px;border-radius:20px;border:1px solid var(--bdr);background:transparent;color:var(--t3);font-size:10px;font-weight:700;cursor:pointer;transition:all .15s}
.fwb:hover{border-color:var(--acc);color:var(--accl)}
.fwb.fw{background:var(--ag);color:var(--accl);border-color:rgba(37,99,235,.3)}

/* MOBILE BOTTOM NAV */
.mob-nav{display:none;position:fixed;bottom:0;left:0;right:0;z-index:100;
  background:rgba(6,9,15,.98);backdrop-filter:blur(20px);border-top:1px solid var(--bdr);
  height:var(--mob);align-items:stretch}
.mni{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;cursor:pointer;color:var(--t3);font-size:10px;font-weight:600;padding:5px 0;
  border:none;background:transparent;font-family:'Manrope',sans-serif;position:relative;transition:color .15s}
.mni.active,.mni:hover{color:var(--accl)}
.mnico{font-size:19px}
.mob-badge{position:absolute;top:4px;right:calc(50% - 16px);background:var(--ye);
  color:#000;font-size:9px;font-weight:800;width:15px;height:15px;
  border-radius:50%;display:flex;align-items:center;justify-content:center}

/* FILTER BAR */
.fbar{display:flex;gap:6px;overflow-x:auto;padding-bottom:2px;margin-bottom:16px;scrollbar-width:none}
.fbar::-webkit-scrollbar{display:none}
.fchip{padding:7px 14px;border-radius:20px;border:1px solid var(--bdr);background:transparent;
  color:var(--t2);font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;
  white-space:nowrap;font-family:'Manrope',sans-serif}
.fchip.active{background:var(--acc);color:#fff;border-color:var(--acc)}
.fchip:hover{border-color:var(--acc);color:var(--t1)}

/* POST FORM */
.pfw{background:var(--card);border:1px solid var(--bdr);border-radius:16px;overflow:hidden;margin-bottom:18px}
.pfhdr{padding:14px 16px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between}
.pftit{font-size:14px;font-weight:700;display:flex;align-items:center;gap:7px}
.exbtn{padding:8px 15px;background:var(--acc);color:#fff;border:none;border-radius:9px;
  font-family:'Manrope',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;
  display:flex;align-items:center;gap:5px}
.exbtn:hover{background:var(--accd)}
.exbtn.cnc{background:var(--surf);color:var(--t2);border:1px solid var(--bdr)}
.exbtn.cnc:hover{border-color:var(--re);color:var(--re);background:transparent}
.pfbody{padding:16px;display:none;animation:sd .25s ease}
@keyframes sd{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.pfbody.open{display:block}

/* BANNER */
.bua{border:2px dashed var(--bdr2);border-radius:12px;cursor:pointer;transition:all .2s;
  margin-bottom:16px;position:relative;overflow:hidden;min-height:110px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:22px}
.bua:hover{border-color:var(--acc);background:var(--ag)}
.bua.has-img{border-style:solid;border-color:var(--acc);padding:0}
.bprev{width:100%;height:160px;object-fit:cover;border-radius:10px;display:none}
.bua.has-img .bprev{display:block}
.bua.has-img .bph{display:none}
.bph{pointer-events:none;text-align:center}
.bico{font-size:26px;margin-bottom:3px}
.bh1{font-size:13px;color:var(--t2);font-weight:600}
.bh2{font-size:11px;color:var(--t3)}
#banner-inp{display:none}
.bchg{position:absolute;bottom:8px;right:8px;padding:4px 11px;background:rgba(0,0,0,.75);
  color:#fff;border:1px solid rgba(255,255,255,.2);border-radius:7px;font-size:11px;
  cursor:pointer;font-family:'Manrope',sans-serif;display:none}
.bua.has-img .bchg{display:block}

/* FIELDS */
.ff{margin-bottom:13px}
.ff label{display:block;font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--t3);margin-bottom:6px}
.ff .req{color:var(--re);margin-left:2px}
.ff input,.ff select,.ff textarea{width:100%;padding:11px 13px;background:var(--surf);border:1px solid var(--bdr);border-radius:10px;color:var(--t1);font-family:'Manrope',sans-serif;font-size:14px;outline:none;transition:all .2s;-webkit-appearance:none}
.ff input:focus,.ff select:focus,.ff textarea:focus{border-color:var(--acc);box-shadow:0 0 0 3px var(--ag)}
.ff select option{background:var(--card)}
.ff textarea{resize:none;line-height:1.6}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:500px){.fg2{grid-template-columns:1fr}}
.fsec{font-size:11px;font-weight:800;color:var(--t2);letter-spacing:.8px;text-transform:uppercase;margin:16px 0 12px;padding-bottom:8px;border-bottom:1px solid var(--bdr)}

/* PILL SELECTOR */
.cpg{display:flex;flex-wrap:wrap;gap:7px;margin-top:7px}
.cpill{padding:7px 12px;border-radius:20px;border:1px solid var(--bdr);background:transparent;color:var(--t2);font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;user-select:none;font-family:'Manrope',sans-serif}
.cpill:hover{border-color:var(--acc);color:var(--t1)}
.cpill.sel{background:var(--ag);border-color:var(--acc);color:var(--accl)}

/* DOC GRID */
.doc-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
@media(max-width:400px){.doc-grid{grid-template-columns:1fr}}
.ditem{display:flex;align-items:center;gap:8px;padding:9px 11px;background:var(--surf);border:1px solid var(--bdr);border-radius:10px;cursor:pointer;transition:all .15s;user-select:none}
.ditem:hover{border-color:var(--bdr2)}
.ditem.sel{background:rgba(37,99,235,.09);border-color:rgba(37,99,235,.4)}
.dchk{width:17px;height:17px;border-radius:5px;border:2px solid var(--bdr2);background:transparent;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;transition:all .15s}
.ditem.sel .dchk{background:var(--acc);border-color:var(--acc)}
.dlbl{font-size:12px;font-weight:600;color:var(--t2);line-height:1.3}
.ditem.sel .dlbl{color:var(--t1)}

/* SUBMIT */
.sub-btn{width:100%;padding:13px;background:linear-gradient(135deg,var(--acc),#1d4ed8);color:#fff;border:none;border-radius:10px;font-family:'Manrope',sans-serif;font-size:14px;font-weight:800;cursor:pointer;transition:all .2s;margin-top:16px}
.sub-btn:hover{transform:translateY(-1px);box-shadow:0 4px 20px rgba(37,99,235,.35)}
.pnote{background:rgba(202,138,4,.07);border:1px solid rgba(202,138,4,.2);border-radius:9px;padding:10px 13px;font-size:12px;color:var(--ye);margin-top:10px;display:flex;align-items:flex-start;gap:7px;line-height:1.5}

/* TRIAL CARDS */
.tc{background:var(--card);border:1px solid var(--bdr);border-radius:14px;overflow:hidden;margin-bottom:14px;transition:all .2s;animation:fu .3s ease both}
@keyframes fu{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.tc:hover{border-color:rgba(37,99,235,.3);transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.35)}
.tcbanner{width:100%;height:150px;object-fit:cover;display:block}
.tcbnph{display:flex;align-items:center;justify-content:center;font-size:26px;height:70px}
.tcbody{padding:14px}
.tctop{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:11px}
.tccrow{display:flex;align-items:center;gap:9px}
.tcav{width:38px;height:38px;border-radius:50%;background:rgba(37,99,235,.15);border:1.5px solid rgba(37,99,235,.35);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12px;color:#60a5fa;flex-shrink:0}
.tcnm{font-size:13px;font-weight:700}
.tccl{font-size:11px;color:var(--t2);margin-top:1px}
.tcbadges{display:flex;flex-direction:column;align-items:flex-end;gap:4px}
.tcts{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--t3)}
.sb{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:5px;font-size:10px;font-weight:700}
.sbo{background:rgba(22,163,74,.1);color:var(--gr);border:1px solid rgba(22,163,74,.25)}
.sbu{background:rgba(202,138,4,.1);color:var(--ye);border:1px solid rgba(202,138,4,.25)}
.sbc{background:rgba(220,38,38,.1);color:var(--re);border:1px solid rgba(220,38,38,.25)}
.sbp{background:rgba(202,138,4,.12);color:var(--ye);border:1px solid rgba(202,138,4,.3)}
.sdts{width:5px;height:5px;border-radius:50%;background:currentColor}
.stag{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;margin-bottom:8px}
.tctitle{font-family:'Bebas Neue',sans-serif;font-size:25px;letter-spacing:1.5px;line-height:1.1;margin-bottom:7px}
.tcdesc{font-size:13px;color:var(--t2);line-height:1.7;margin-bottom:12px}
.igrid{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;margin-bottom:12px}
@media(min-width:400px){.igrid{grid-template-columns:repeat(4,1fr)}}
.ibox{background:var(--surf);border-radius:8px;padding:8px 9px;text-align:center}
.ilbl{font-family:'JetBrains Mono',monospace;font-size:7px;letter-spacing:1.5px;text-transform:uppercase;color:var(--t3);margin-bottom:3px}
.ival{font-size:12px;font-weight:700}
.pill-row{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px}
.ptag{padding:3px 9px;background:var(--surf);border:1px solid var(--bdr);border-radius:20px;font-size:11px;color:var(--t2)}
.docsbox{background:rgba(202,138,4,.05);border:1px solid rgba(202,138,4,.18);border-radius:9px;padding:10px 12px;margin-bottom:12px}
.docsbox-title{font-size:10px;font-weight:800;color:var(--ye);letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px}
.docsbox-list{display:flex;flex-wrap:wrap;gap:5px}
.dtag{display:flex;align-items:center;gap:4px;padding:3px 9px;background:rgba(202,138,4,.08);border:1px solid rgba(202,138,4,.2);border-radius:20px;font-size:11px;color:var(--ye);font-weight:600}
.cbar{background:rgba(37,99,235,.05);border:1px solid rgba(37,99,235,.15);border-radius:9px;padding:9px 12px;margin-bottom:12px;font-size:12px;color:var(--t2)}
.tca{display:flex;align-items:center;gap:5px;padding-top:11px;border-top:1px solid var(--bdr);flex-wrap:wrap}
.abt{display:flex;align-items:center;gap:5px;padding:7px 12px;border-radius:8px;border:1px solid var(--bdr);background:transparent;color:var(--t2);font-family:'Manrope',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:all .15s}
.abt:hover{background:var(--surf);color:var(--t1);border-color:var(--acc)}
.abt.liked{color:#f87171;border-color:rgba(220,38,38,.4);background:rgba(220,38,38,.06)}
.apbtn{margin-left:auto;padding:7px 16px;background:var(--acc);color:#fff;border:none;border-radius:8px;font-family:'Manrope',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s}
.apbtn:hover{background:var(--accd)}
