function doApprove(){
  const p=posts.find(x=>x.id===tid);p.approved=true;
  const note=document.getElementById('ap-note').value.trim();
  if(note){msgs.unshift({from:cu.name,to:p.coach,trial:p.title,text:`"${p.title}" APPROVED. ${note}`,ts:'Just now'});renderMsgs();document.getElementById('bdot').style.display='block';}
  closeMod('ap-modal');renderAdminP();renderFeed();updateStats();showN('✅ "'+p.title+'" is now live!','success');
}
function openRP(id){tid=id;document.getElementById('rj-reason').value='';document.getElementById('rj-modal').style.display='flex';}
function doReject(){
  const reason=document.getElementById('rj-reason').value.trim();
  if(!reason){showN('Please provide a reason','error');return;}
  const p=posts.find(x=>x.id===tid);
  msgs.unshift({from:cu.name,to:p.coach,trial:p.title,text:`"${p.title}" rejected. Reason: ${reason}`,ts:'Just now'});
  posts=posts.filter(x=>x.id!==tid);
  renderMsgs();document.getElementById('bdot').style.display='block';
  closeMod('rj-modal');renderAdminP();renderFeed();updateStats();showN('❌ Trial rejected.','warn');
}
function closeMod(id){document.getElementById(id).style.display='none';}
function toggleMsgs(){
  const w=document.getElementById('msgs-wrap');
  const open=w.style.display!=='none';
  w.style.display=open?'none':'block';
  if(!open){document.getElementById('bdot').style.display='none';renderMsgs();}
}
function renderMsgs(){
  const l=document.getElementById('msgs-list');
  if(!msgs.length){l.innerHTML='<div style="padding:12px;font-size:12px;color:var(--t3)">No messages yet.</div>';return;}
  l.innerHTML=msgs.map(m=>`<div class="mli"><div class="mlif">${m.from} → ${m.to} <span style="color:var(--t3);font-weight:500">re: ${m.trial}</span></div><div class="mlit">${m.text}</div><div class="mlis">${m.ts}</div></div>`).join('');
}

// ── INTERACTIONS ──
function togLike(id){const p=posts.find(x=>x.id===id);if(p.likedBy.includes(cu.name)){p.likedBy=p.likedBy.filter(n=>n!==cu.name);p.likes--;}else{p.likedBy.push(cu.name);p.likes++;}renderFeed();}
function applyT(id){const p=posts.find(x=>x.id===id);if(p.appliedBy.includes(cu.name))return;p.appliedBy.push(cu.name);p.applicants++;renderFeed();updateStats();showN('🎉 '+L().applied+' — "'+p.title+'"!','success');}
function closeT(id){posts.find(x=>x.id===id).status='closed';renderFeed();showN(L().close_trial,'info');}
function togCm(id){document.getElementById('cmw-'+id).classList.toggle('open');}
function addCm(id){
  const inp=document.getElementById('cmi-'+id);const text=inp.value.trim();if(!text)return;
  posts.find(x=>x.id===id).comments.push({user:cu.name,role:cu.role,text});
  inp.value='';
  const list=document.getElementById('cml-'+id);
  const d=document.createElement('div');d.className='cmt';
  d.innerHTML=`<div class="cmav cc">${cu.ini}</div><div><div class="cmnm">${cu.name}</div><div class="cmtx">${text}</div></div>`;
  list.appendChild(d);
}

// ── RIGHT PANEL ──
function renderRP(){
  const coaches=[...new Map(posts.map(p=>[p.coach,{name:p.coach,club:p.club}])).values()].slice(0,5);
  document.getElementById('rp-coaches').innerHTML=coaches.map(c=>{
    const ini=c.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    const fw=followed.includes(c.name);
    return`<div class="cr"><div class="crav">${ini}</div><div class="cri"><div class="crn">${c.name}</div><div class="crc">${c.club}</div></div><button class="fwb ${fw?'fw':''}" onclick="togFollow('${c.name}',this)">${fw?'Following':'Follow'}</button></div>`;
  }).join('');
}
function togFollow(n,btn){
  if(followed.includes(n)){followed=followed.filter(x=>x!==n);btn.textContent='Follow';btn.classList.remove('fw');}
  else{followed.push(n);btn.textContent='Following';btn.classList.add('fw');showN('Following '+n,'info');}
}

function updateStats(){
  document.getElementById('st-a').textContent=posts.filter(p=>p.approved&&p.status==='open').length;
  document.getElementById('st-c').textContent=new Set(posts.map(p=>p.coach)).size;
  document.getElementById('st-ap').textContent=posts.reduce((s,p)=>s+p.applicants,0);
  document.getElementById('st-p').textContent=posts.filter(p=>!p.approved).length;
}

function showN(msg,type='info'){
  const n=document.getElementById('notif');n.textContent=msg;n.className='notif '+type+' show';
  setTimeout(()=>n.classList.remove('show'),3400);
}

selRole('coach');applyT();
</script>
</body>
</html>
