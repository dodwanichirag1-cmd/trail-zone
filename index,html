  msgs.unshift({from:cu.name,to:p.coach,trial:p.title,text:msg,ts:'Just now'});
  renderMsgs();closeMod('cm-modal');showN('✉️ Message sent to '+p.coach,'success');
  document.getElementById('bdot').style.display='block';
}
function openAP(id){
  tid=id;const p=posts.find(x=>x.id===id);
  document.getElementById('ap-info').innerHTML=`Approving <b>"${p.title}"</b> by ${p.coach} will publish it to the live feed.`;
  document.getElementById('ap-note').value='';
  document.getElementById('ap-modal').style.display='flex';
