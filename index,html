// ── STATE ──
let curLang='en',cu=null,selRole_='coach',navF='feed',chipF='all',sportF='all';
let bannerUrl=null,selSkills=[],selDocs=[],msgs=[],followed=[],tid=null,editTid=null;

const L=()=>T[curLang];

// ── LANG ──
function toggleLangDrop(){document.getElementById('lang-drop').classList.toggle('open')}
document.addEventListener('click',e=>{if(!document.getElementById('lang-wrap').contains(e.target))document.getElementById('lang-drop').classList.remove('open')});
function setLang(lang,el,label){
  curLang=lang;
  document.getElementById('lang-cur').textContent=label;
  document.querySelectorAll('.lang-opt').forEach(o=>o.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('lang-drop').classList.remove('open');
  applyT();
  if(cu)reRenderAll();
}
function applyT(){
  document.querySelectorAll('[data-t]').forEach(el=>{const k=el.getAttribute('data-t');if(L()[k])el.textContent=L()[k];});
  document.querySelectorAll('[data-ph]').forEach(el=>{const k=el.getAttribute('data-ph');if(L()[k])el.placeholder=L()[k];});
}

// ── LOGIN ──
function selRole(r){
  selRole_=r;
  ['coach','player'].forEach(x=>document.getElementById('tab-'+x).className='rtab '+x);
  document.getElementById('tab-'+r).className='rtab active '+r;
  document.getElementById('l-club-w').style.display=r==='coach'?'block':'none';
  document.getElementById('l-sport-w').style.display=r==='player'?'block':'none';
  const b=document.getElementById('lbtn');
  b.className='lbtn '+(r==='coach'?'cb':'pb');
  b.innerHTML=`<span data-t="${r==='coach'?'enter_coach':'enter_player'}">${L()[r==='coach'?'enter_coach':'enter_player']}</span>`;
}

function doLogin(){
  const name=document.getElementById('l-name').value.trim();
  if(!name){showN('Please enter your name','error');return;}
  const raw=name.trim();

  // OWNER login — secret name triggers full admin
  if(raw===OWNER_SECRET){
    cu={name:'Owner',role:'owner',club:'TrialZone HQ',ini:'OW',isOwner:true,isAdmin:true};
  } else if(raw===ADMIN_KEY){
    cu={name:'Admin',role:'admin',club:'TrialZone',ini:'AD',isAdmin:true,isOwner:false};
  } else {
    cu={name:raw,role:selRole_,club:document.getElementById('l-club').value.trim()||'Independent',sport:document.getElementById('l-sport').value,ini:raw.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2),isAdmin:false,isOwner:false};
  }
  document.getElementById('login-screen').style.display='none';
  document.getElementById('app').style.display='block';
  setupApp();
}

function doLogout(){
  cu=null;
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('app').style.display='none';
  document.getElementById('nav-uav-wrap').style.display='none';
  document.getElementById('out-btn').style.display='none';
  document.getElementById('bell-btn').style.display='none';
  selRole('coach');
}

function setupApp(){
  const av=document.getElementById('nav-av');
  av.textContent=cu.ini;
  av.className='uav '+(cu.isOwner?'admin':cu.isAdmin?'admin':cu.role);
  document.getElementById('nav-nm').textContent=cu.name;
  const rp=document.getElementById('nav-rp');
  rp.textContent=cu.isOwner?'👑 Owner':cu.isAdmin?'🛡️ Admin':cu.role==='coach'?'🏅 '+L().role_coach:'⚡ '+L().role_player;
  rp.className='rpill '+(cu.isOwner||cu.isAdmin?'admin':cu.role);
  document.getElementById('nav-uav-wrap').style.display='flex';
  document.getElementById('out-btn').style.display='block';

  // Admin/owner: show bell + admin sidebar item
  const showAdmin=cu.isAdmin||cu.isOwner;
  document.getElementById('bell-btn').style.display=showAdmin?'flex':'none';
  document.getElementById('si-admin').style.display=showAdmin?'flex':'none';
  document.getElementById('mni-admin').style.display=showAdmin?'flex':'none';

  // Coach post form
  const showPost=cu.role==='coach'&&!cu.isAdmin&&!cu.isOwner;
  document.getElementById('coach-pf').style.display=showPost?'block':'none';
  document.getElementById('mni-post').style.display=showPost?'flex':'none';

  document.getElementById('si-mine-lbl').textContent=cu.role==='coach'?L().my_posts:L().my_apps;
  document.getElementById('mob-nav').style.display='flex';

  buildSports();buildDocGrid();updateSkills();
  renderFeed();renderRP();updateStats();applyT();
}

function reRenderAll(){
  if(!cu)return;
  document.getElementById('si-mine-lbl').textContent=cu.role==='coach'?L().my_posts:L().my_apps;
  buildSports();renderFeed();renderRP();applyT();
}

// ── SPORTS ──
function buildSports(){
  const sp=['Football','Basketball','Cricket','Athletics','Badminton','Swimming','Tennis','Hockey'];
  const make=(onclick,cls='')=>`<div class="spp${cls}" onclick="${onclick}"><div class="spdot" style="background:var(--t4)"></div>${L().all_sports}</div>`
